{
    "experiment_name": "mnist_manysgd_small_grouped",
    "description": "MNIST Many-SGD Small with grouped initial weights: 3 init weights × 5 runs → 1 GD → 2 runs per source",
    
    "data": {
        "name": "mnist",
        "sample_size": 6400,
        "replacement": true
    },
    
    "model": {
        "name": "class",
        "class_name": "FlexibleMLP",
        "hidden_dim": 8,
        "num_hidden_layers": 1,
        "input_downsample": 6
    },
    
    "tunnels": [
        {
            "name": "tunnel_0",
            "description": "SGD: 3 initial weights × 5 runs (15 total)",
            "mode": "steps",
            "steps": 10000,
            "optimizer": "sgd",
            "lr": 0.1,
            "batch_size": 64,
            "n_initial_weights": 3,
            "n_runs": 5,
            "trackers": {
                "metrics": {"every": 1},
                "weights": {"every": 1}
            },
            "eval_every": 100,
            "save_checkpoint": true,
            "source_mode": null
        },
        {
            "name": "tunnel_1",
            "description": "GD: 1 run per source (15 total from 15 sources)",
            "mode": "epochs",
            "epochs": 10,
            "optimizer": "sgd",
            "lr": 0.01,
            "batch_size": 6400,
            "dataloader_mode": "fullbatch",
            "n_runs": 1,
            "trackers": {
                "metrics": {"every": 1},
                "weights": {"every": 1}
            },
            "eval_every": 1,
            "save_checkpoint": true,
            "source_mode": "cartesian"
        },
        {
            "name": "tunnel_2",
            "description": "Many SGD: 2 runs per source (30 total from 15 sources)",
            "mode": "steps",
            "steps": 5000,
            "optimizer": "sgd",
            "lr": 0.1,
            "batch_size": 64,
            "n_runs": 5,
            "trackers": {
                "metrics": {"every": 1},
                "weights": {"every": 1}
            },
            "eval_every": 100,
            "save_checkpoint": true,
            "source_mode": "cartesian"
        }
    ],
    
    "device": "cpu",
    "dtype": "float32"
}
